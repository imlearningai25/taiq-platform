# TaIQ job seeder cron schedule
# Runs every Sunday at 2:00 AM UTC
# To change frequency, edit this file and restart the job-seeder container:
#   docker compose restart job-seeder

# ┌────────────── minute (0-59)
# │  ┌─────────── hour (0-23)
# │  │  ┌──────── day of month (1-31)
# │  │  │  ┌───── month (1-12)
# │  │  │  │  ┌── day of week (0=Sun … 6=Sat)
# │  │  │  │  │
  0  2  *  *  0  cd /app && python seed_new_jobs.py >> /proc/1/fd/1 2>&1
