# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=TaIQ
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=taiq
POSTGRES_PASSWORD=taiq_secret
POSTGRES_DB=taiq_db
DATABASE_URL=postgresql+asyncpg://taiq:taiq_secret@db:5432/taiq_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:80"]

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Set EMAIL_ENABLED=true and fill in SMTP credentials to send real emails.
# Example below uses Gmail — create an App Password at myaccount.google.com/apppasswords
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=TaIQ
SMTP_FROM_EMAIL=noreply@taiq.us
FRONTEND_URL=http://localhost:8090

# ── AI (Claude) ───────────────────────────────────────────────────────────────
# Required for AI-powered job file parsing (CSV/PDF/DOCX → form fields)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
